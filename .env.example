# Anthropic API key (console.anthropic.com) - used for script generation
ANTHROPIC_API_KEY=

# Pexels API key (pexels.com/api) - free, used for royalty-free video/image sourcing
PEXELS_API_KEY=

# Optional: ElevenLabs API key (elevenlabs.io) - only needed if you upgrade voice quality later
ELEVENLABS_API_KEY=

# TikTok for Developers (developers.tiktok.com) - Sandbox "dev" app credentials
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
